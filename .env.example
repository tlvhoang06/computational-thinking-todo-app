# Backend settings
GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id
BACKEND_CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Frontend / Firebase Auth settings
# Firebase Web API key is an app identifier, not a service account secret.
# Keep it in environment config for deployment flexibility.
FIREBASE_API_KEY=your-firebase-web-api-key
API_BASE_URL=http://localhost:8000

# Optional advanced Google OAuth flow
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8501
